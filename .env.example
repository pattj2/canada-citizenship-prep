# ============================================================
# Canada Citizenship Prep — Environment Variables
# Copy this file to .env and fill in your values.
# For local Docker development the defaults below work as-is.
# ============================================================

# --- Database (PostgreSQL via Docker Compose) ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/citizenprep

# --- NextAuth ---
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=change_this_to_a_random_secret_at_least_32_chars
NEXTAUTH_URL=http://localhost:3000

# --- Admin ---
# The username that will have ADMIN role (created at first login)
ADMIN_USERNAME=admin

# --- Redis (optional — used for rate limiting) ---
REDIS_URL=redis://redis:6379

# --- Node ---
NODE_ENV=development
